---
import { config } from '../config';

const { linkedin } = config.urls;
---

<footer class="bg-void py-8 border-t border-void-border">
  <div class="max-w-content mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">

    <!-- Logo -->
    <div class="flex items-center gap-2.5">
      <div class="w-6 h-6 rounded-md bg-emerald/10 border border-emerald/20 flex items-center justify-center">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
          <path d="M3 8l4 4 6-7" stroke="#2AF598" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="font-sans text-sm text-text-muted">
        &copy; 2026 Execution Engine
      </span>
    </div>

    <!-- Links -->
    <div class="flex items-center gap-6">
      <a href="/score" class="text-sm text-text-dim hover:text-off-white transition-colors font-sans">
        Free Assessment
      </a>
      <a href="#faq" class="text-sm text-text-dim hover:text-off-white transition-colors font-sans">
        FAQ
      </a>
      <a
        href={linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-dim hover:text-off-white transition-colors"
        aria-label="LinkedIn"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
        </svg>
      </a>
    </div>

  </div>
</footer>
