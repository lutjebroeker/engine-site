---

<section class="relative py-12 bg-void border-y border-void-border overflow-hidden">
  <div class="max-w-wide mx-auto px-6">

    <p class="text-center text-xs font-sans uppercase tracking-widest text-text-dim mb-8">
      Tool-agnostisch — schrijf waar je wilt, het systeem plugt erin
    </p>

    <div class="relative overflow-hidden">
      <div class="flex animate-marquee gap-16 items-center">
        {[...platforms, ...platforms].map((p) => (
          <div class="flex items-center gap-2.5 flex-shrink-0 opacity-45 hover:opacity-80 transition-opacity">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted">
              <path d={p.icon} />
            </svg>
            <span class="text-sm text-text-muted font-sans whitespace-nowrap">{p.name}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
