---
import { config } from '../config';

const { webhookUrl } = config.scorecard;
const { bookCall, linkedin } = config.urls;
const { price } = config.founding;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const questions = [
  {
    text: "How much of your week is spent on strategic priorities vs. reactive tasks?",
    options: [
      { label: "Almost entirely strategic", score: 25 },
      { label: "Mostly strategic, some reactive", score: 19 },
      { label: "About half and half", score: 12 },
      { label: "Mostly reactive, little strategic", score: 6 },
      { label: "Entirely reactive — I'm firefighting all day", score: 0 },
    ],
  },
  {
    text: "Do you start each week with clear, measurable priorities?",
    options: [
      { label: "Always — written down with specific outcomes", score: 25 },
      { label: "Usually — I have a rough plan", score: 19 },
      { label: "Sometimes — depends on the week", score: 12 },
      { label: "Rarely — I dive straight into email/Slack", score: 6 },
      { label: "Never — the week happens to me", score: 0 },
    ],
  },
  {
    text: "By Friday, what percentage of your Monday priorities actually got done?",
    options: [
      { label: "90%+ consistently", score: 25 },
      { label: "Around 70% most weeks", score: 19 },
      { label: "About 50/50", score: 12 },
      { label: "Less than 30%", score: 6 },
      { label: "I can't even remember what I planned Monday", score: 0 },
    ],
  },
  {
    text: "When an urgent request comes in, how do you decide whether to act on it?",
    options: [
      { label: "Clear framework — I assess against my priorities", score: 25 },
      { label: "I usually pause and think before reacting", score: 19 },
      { label: "Depends on who's asking", score: 12 },
      { label: "I tend to react first, think later", score: 6 },
      { label: "I drop everything — everything feels urgent", score: 0 },
    ],
  },
  {
    text: "Do you protect blocks of time for deep/strategic work?",
    options: [
      { label: "Daily, non-negotiable — it's in my calendar", score: 25 },
      { label: "A few times a week, usually", score: 19 },
      { label: "I try, but meetings override them", score: 12 },
      { label: "Rarely — my calendar is not my own", score: 6 },
      { label: "Never — what's a focus block?", score: 0 },
    ],
  },
  {
    text: "How do you know if you had a productive week?",
    options: [
      { label: "Objective metric — I track completion rate", score: 25 },
      { label: "I review what I accomplished vs. planned", score: 19 },
      { label: "I go by gut feeling", score: 12 },
      { label: "If I'm not exhausted, I assume I was productive", score: 6 },
      { label: "I don't really think about it", score: 0 },
    ],
  },
  {
    text: "When you set quarterly goals, how often do you hit them?",
    options: [
      { label: "Almost always — 80%+ completion", score: 25 },
      { label: "More often than not", score: 19 },
      { label: "About half the time", score: 12 },
      { label: "Rarely — things change too fast", score: 6 },
      { label: "I don't set quarterly goals", score: 0 },
    ],
  },
  {
    text: "Do you have a system that holds you accountable to your own commitments?",
    options: [
      { label: "Yes — active, daily, impossible to ignore", score: 25 },
      { label: "Yes — but I don't use it consistently", score: 19 },
      { label: "Sort of — I have reminders and lists", score: 12 },
      { label: "Not really — just my own memory", score: 6 },
      { label: "No — I rely entirely on willpower", score: 0 },
    ],
  },
  {
    text: "How often do you reflect on what worked vs. what didn't?",
    options: [
      { label: "Weekly, structured, with notes", score: 25 },
      { label: "Regularly, but informally", score: 19 },
      { label: "Occasionally, when something goes wrong", score: 12 },
      { label: "Rarely — I'm always looking forward", score: 6 },
      { label: "Almost never", score: 0 },
    ],
  },
  {
    text: "If someone measured your execution rate right now, what would it be?",
    options: [
      { label: "Above 85% — I do what I say I'll do", score: 25 },
      { label: "Around 70% — mostly consistent", score: 19 },
      { label: "Around 50% — hit or miss", score: 12 },
      { label: "Below 40% — more miss than hit", score: 6 },
      { label: "Below 20% — I'd rather not know", score: 0 },
    ],
  },
];

const questionLabels = [
  "Strategic focus",
  "Weekly planning",
  "Execution rate",
  "Priority defense",
  "Focus protection",
  "Productivity measure",
  "Goal completion",
  "Accountability system",
  "Reflection habit",
  "Self-awareness",
];
---

<div id="quiz-container" class="min-h-screen bg-void">

  <!-- Nav bar -->
  <nav class="border-b border-void-border bg-void/80 backdrop-blur-xl sticky top-0 z-10">
    <div class="max-w-content mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-sans font-semibold text-sm text-off-white hover:text-emerald transition-colors">
        <div class="w-6 h-6 rounded-md bg-emerald/10 border border-emerald/20 flex items-center justify-center">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8l4 4 6-7" stroke="#2AF598" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        Execution Engine
      </a>
      <span id="nav-label" class="font-sans text-sm text-text-muted">Execution Score Assessment</span>
    </div>
  </nav>

  <!-- Progress bar -->
  <div id="progress-wrapper" class="bg-void-light border-b border-void-border">
    <div class="max-w-content mx-auto px-6 py-3 flex items-center gap-4">
      <span id="progress-label" class="font-sans text-xs text-text-muted flex-shrink-0">Question 1 of 10</span>
      <div class="flex-1 h-1.5 bg-void-border rounded-full overflow-hidden">
        <div id="progress-fill" class="h-full bg-emerald rounded-full transition-all duration-300 ease-out" style="width: 10%"></div>
      </div>
      <span id="progress-pct" class="font-mono text-xs text-text-muted flex-shrink-0 w-8 text-right">10%</span>
    </div>
  </div>

  <!-- Quiz steps -->
  <div class="max-w-narrow mx-auto px-6 py-12">

    {questions.map((q, i) => (
      <div
        id={`step-${i + 1}`}
        class={`quiz-step ${i === 0 ? '' : 'hidden'}`}
        data-step={i + 1}
      >
        <p class="font-sans text-sm font-semibold text-emerald uppercase tracking-widest mb-4">
          Question {i + 1} of 10
        </p>
        <h2 class="font-sans font-bold text-heading-mobile text-off-white mb-8 leading-snug">
          {q.text}
        </h2>

        <div class="options space-y-3 mb-10">
          {q.options.map((opt, j) => (
            <button
              class="option-btn w-full text-left px-5 py-4 rounded-lg border border-void-border bg-void-card font-sans text-base text-off-white hover:border-emerald/30 hover:bg-emerald/5 transition-all duration-150"
              data-step={i + 1}
              data-index={j}
              data-score={opt.score}
            >
              {opt.label}
            </button>
          ))}
        </div>

        <div class="flex items-center justify-between">
          <button
            class="back-btn font-sans text-sm text-text-muted hover:text-off-white transition-colors flex items-center gap-1.5 disabled:opacity-30"
            data-step={i + 1}
            disabled={i === 0}
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Back
          </button>
          <button
            class="next-btn inline-flex items-center gap-2 bg-emerald text-void rounded-lg py-3 px-6 font-sans font-semibold text-base transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed hover:brightness-110 hover:-translate-y-px"
            data-step={i + 1}
            disabled
          >
            {i === 9 ? 'See my score' : 'Next'}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    ))}

    <!-- Email capture step -->
    <div id="capture-step" class="quiz-step hidden">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald/10 border border-emerald/20 mb-6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke="#2AF598" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="font-sans font-bold text-heading-mobile text-off-white mb-3">Your score is ready.</h2>
        <p class="font-sans text-base text-text-muted max-w-sm mx-auto">
          Enter your email to see your full results and get personalized recommendations.
        </p>
      </div>

      <form id="capture-form" class="space-y-4 mb-6" novalidate>
        <div>
          <label for="capture-name" class="block font-sans text-sm font-medium text-off-white mb-1.5">
            Name <span class="text-text-dim font-normal">(optional)</span>
          </label>
          <input
            type="text"
            id="capture-name"
            placeholder="Your name"
            class="w-full border border-void-border rounded-lg px-4 py-3 font-sans text-base text-off-white bg-void-card placeholder:text-text-dim focus:outline-none focus:border-emerald/50 focus:ring-1 focus:ring-emerald/50 transition-colors"
          />
        </div>
        <div>
          <label for="capture-email" class="block font-sans text-sm font-medium text-off-white mb-1.5">
            Email <span class="text-amber font-medium">*</span>
          </label>
          <input
            type="email"
            id="capture-email"
            placeholder="you@company.com"
            class="w-full border border-void-border rounded-lg px-4 py-3 font-sans text-base text-off-white bg-void-card placeholder:text-text-dim focus:outline-none focus:border-emerald/50 focus:ring-1 focus:ring-emerald/50 transition-colors"
          />
          <p id="email-error" class="hidden mt-1.5 text-sm text-amber font-sans">Please enter a valid email address.</p>
        </div>

        <button
          type="submit"
          id="capture-submit"
          class="w-full bg-emerald text-void rounded-lg py-3.5 px-6 font-sans font-semibold text-base hover:brightness-110 transition-all duration-200 hover:-translate-y-px flex items-center justify-center gap-2"
        >
          <span id="capture-btn-text">See my results</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </form>

      <div class="text-center">
        <button
          id="capture-skip"
          class="font-sans text-sm text-text-dim hover:text-text-muted transition-colors underline underline-offset-2"
        >
          Skip — just show my results
        </button>
      </div>
    </div>

    <!-- Results step -->
    <div id="results-step" class="quiz-step hidden">
      <!-- Populated by JS -->
    </div>

  </div>
</div>

<style>
  .quiz-step {
    transition: opacity 300ms ease-out, transform 300ms ease-out;
  }
  .quiz-step.hidden {
    display: none;
  }
  .quiz-step.exiting {
    opacity: 0;
    transform: translateX(-1rem);
  }
  .quiz-step.entering {
    opacity: 0;
    transform: translateX(1rem);
  }
  .option-btn.selected {
    background-color: rgba(42, 245, 152, 0.1);
    border-color: #2AF598;
    color: #E8E8ED;
  }
</style>

<script define:vars={{ webhookUrl, bookCall, linkedin, price, supabaseUrl, supabaseKey }}>
  // ─── Data ───────────────────────────────────────────────────────────────────

  const TIERS = [
    {
      name: 'Strategic Operator',
      min: 80,
      color: '#2AF598',
      bgColor: 'rgba(42, 245, 152, 0.1)',
      borderColor: 'rgba(42, 245, 152, 0.2)',
      message: "You're already executing at a high level. You don't need an accountability system — you ARE one. Keep doing what you're doing.",
      ctaLabel: 'Follow our build on LinkedIn →',
      ctaHref: linkedin,
    },
    {
      name: 'Aware but Drifting',
      min: 50,
      color: '#F5A623',
      bgColor: 'rgba(245, 166, 35, 0.1)',
      borderColor: 'rgba(245, 166, 35, 0.2)',
      message: "You see the gap between intention and execution. You have the awareness — but awareness alone isn't closing it. You're one system away from consistency.",
      ctaLabel: 'Book a 20-minute call to explore if the Execution Engine fits your situation →',
      ctaHref: bookCall,
    },
    {
      name: 'Operationally Trapped',
      min: 25,
      color: '#F59E0B',
      bgColor: 'rgba(245, 158, 11, 0.1)',
      borderColor: 'rgba(245, 158, 11, 0.2)',
      message: "You're not unproductive — you're operationally trapped. You spend your days solving everyone else's problems while your own strategic priorities collect dust. This isn't a willpower problem. It's a systems problem.",
      ctaLabel: `Apply for a founding spot — 12 available at ${price} →`,
      ctaHref: '/#offer',
    },
    {
      name: 'In Survival Mode',
      min: 0,
      color: '#9CA3AF',
      bgColor: 'rgba(156, 163, 175, 0.1)',
      borderColor: 'rgba(156, 163, 175, 0.2)',
      message: "You're in deep reactive mode. Before an execution system can help, you may need to address the organizational or structural issues causing the chaos. But when you're ready — we're here.",
      ctaLabel: 'Download our free Execution Framework →',
      ctaHref: '#',
    },
  ];

  const QUESTION_LABELS = [
    'Strategic focus', 'Weekly planning', 'Execution rate', 'Priority defense',
    'Focus protection', 'Productivity measure', 'Goal completion',
    'Accountability system', 'Reflection habit', 'Self-awareness',
  ];

  // ─── State ──────────────────────────────────────────────────────────────────

  let currentStep = 1;
  let answers = []; // { step, index, score, label }
  let isAnimating = false;

  // ─── DOM refs ───────────────────────────────────────────────────────────────

  const progressWrapper = document.getElementById('progress-wrapper');
  const progressFill = document.getElementById('progress-fill');
  const progressLabel = document.getElementById('progress-label');
  const progressPct = document.getElementById('progress-pct');
  const captureStep = document.getElementById('capture-step');
  const resultsStep = document.getElementById('results-step');

  function getStep(n) {
    return document.getElementById(`step-${n}`);
  }

  // ─── Navigation ─────────────────────────────────────────────────────────────

  function updateProgress(step) {
    const pct = Math.round((step / 10) * 100);
    progressFill.style.width = `${pct}%`;
    progressLabel.textContent = `Question ${step} of 10`;
    progressPct.textContent = `${pct}%`;
  }

  function animateTransition(outEl, inEl, direction = 'forward') {
    if (isAnimating) return;
    isAnimating = true;

    const outClass = direction === 'forward' ? 'exiting' : 'entering-back';
    const inInitClass = direction === 'forward' ? 'entering' : 'exiting-back';

    // Prepare incoming element
    inEl.classList.remove('hidden');
    inEl.style.opacity = '0';
    inEl.style.transform = direction === 'forward' ? 'translateX(1rem)' : 'translateX(-1rem)';

    // Animate out
    outEl.style.opacity = '0';
    outEl.style.transform = direction === 'forward' ? 'translateX(-1rem)' : 'translateX(1rem)';

    setTimeout(() => {
      outEl.classList.add('hidden');
      outEl.style.opacity = '';
      outEl.style.transform = '';

      inEl.style.opacity = '';
      inEl.style.transform = '';

      isAnimating = false;
    }, 300);
  }

  function goToStep(n, direction = 'forward') {
    const from = currentStep <= 10 ? getStep(currentStep) : captureStep;
    const to = getStep(n);
    if (!to) return;

    animateTransition(from, to, direction);
    currentStep = n;
    updateProgress(n);
    progressWrapper.style.display = '';

    // Restore previously selected option
    const prev = answers.find(a => a.step === n);
    if (prev) {
      const btns = to.querySelectorAll('.option-btn');
      btns.forEach((btn, i) => {
        btn.classList.toggle('selected', i === prev.index);
      });
      to.querySelector('.next-btn').disabled = false;
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function showCapture() {
    const from = getStep(10);
    animateTransition(from, captureStep);
    progressWrapper.style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function showResults() {
    const score = Math.round(answers.reduce((s, a) => s + a.score, 0) / 250 * 100);
    const tier = TIERS.find(t => score >= t.min) || TIERS[TIERS.length - 1];

    // Build breakdown — sort by score ascending, show all 10
    const breakdown = [...answers].sort((a, b) => a.score - b.score);

    resultsStep.innerHTML = buildResultsHTML(score, tier, breakdown);

    const from = captureStep.classList.contains('hidden') ? getStep(10) : captureStep;
    animateTransition(from, resultsStep);
    progressWrapper.style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function buildResultsHTML(score, tier, breakdown) {
    const shareText = encodeURIComponent(`I just took the Execution Score Assessment and scored ${score}/100 — "${tier.name}". Curious where you land? execution-engine.com/score`);
    const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent('https://execution-engine.com/score')}&summary=${shareText}`;

    return `
      <div class="text-center mb-12">
        <div class="inline-block px-3 py-1.5 rounded-full text-xs font-semibold font-sans uppercase tracking-widest mb-4 border"
          style="background:${tier.bgColor}; color:${tier.color}; border-color:${tier.borderColor}">
          Your Execution Score
        </div>
        <div class="font-mono text-7xl md:text-8xl font-bold mb-3 leading-none" style="color:${tier.color}">
          ${score}
        </div>
        <div class="font-mono text-sm text-text-dim mb-6">out of 100</div>
        <h2 class="font-sans font-bold text-3xl text-off-white mb-5">${tier.name}</h2>
        <p class="font-sans text-lg text-text-muted max-w-narrow mx-auto leading-relaxed">
          ${tier.message}
        </p>
      </div>

      <!-- CTA -->
      <div class="text-center mb-12">
        <a
          href="${tier.ctaHref}"
          class="inline-flex items-center gap-2 rounded-lg py-4 px-8 font-sans font-semibold text-base text-void transition-all duration-200 hover:-translate-y-px hover:brightness-110"
          style="background:${tier.color}"
        >
          ${tier.ctaLabel}
        </a>
      </div>

      <!-- Score breakdown -->
      <div class="border border-void-border rounded-xl overflow-hidden mb-8">
        <div class="px-6 py-4 bg-void-card border-b border-void-border">
          <h3 class="font-sans font-semibold text-sm text-off-white uppercase tracking-wide">Score breakdown</h3>
        </div>
        ${breakdown.map(a => {
          const pct = Math.round(a.score / 25 * 100);
          const barColor = a.score >= 19 ? '#2AF598' : a.score >= 12 ? '#F5A623' : '#F59E0B';
          return `
          <div class="px-6 py-4 border-b border-void-border last:border-b-0 flex items-center gap-4">
            <div class="flex-1 min-w-0">
              <div class="font-sans text-sm font-medium text-off-white">${QUESTION_LABELS[a.step - 1]}</div>
              <div class="mt-1.5 h-1.5 bg-void-border rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-500" style="width:${pct}%; background:${barColor}"></div>
              </div>
            </div>
            <div class="font-mono text-sm flex-shrink-0 w-10 text-right" style="color:${barColor}">${a.score}/25</div>
          </div>`;
        }).join('')}
      </div>

      <!-- Secondary actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a
          href="${linkedinShareUrl}"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-sans text-sm font-medium text-emerald hover:brightness-110 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
          Share your score on LinkedIn
        </a>
        <span class="hidden sm:block text-void-border">|</span>
        <a href="/" class="font-sans text-sm text-text-muted hover:text-off-white transition-colors">
          ← How the Execution Engine works
        </a>
      </div>
    `;
  }

  // ─── Event listeners ─────────────────────────────────────────────────────────

  // Option selection
  document.querySelectorAll('.option-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.step);
      const index = parseInt(btn.dataset.index);
      const score = parseInt(btn.dataset.score);
      const label = btn.textContent.trim();

      // Update answers state
      answers = answers.filter(a => a.step !== step);
      answers.push({ step, index, score, label });

      // Update UI selection
      const parent = btn.closest('.options');
      parent.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');

      // Enable next button
      const stepEl = document.getElementById(`step-${step}`);
      stepEl.querySelector('.next-btn').disabled = false;
    });
  });

  // Next buttons
  document.querySelectorAll('.next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.step);
      if (step < 10) {
        goToStep(step + 1, 'forward');
      } else {
        showCapture();
      }
    });
  });

  // Back buttons
  document.querySelectorAll('.back-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.step);
      if (step > 1) {
        goToStep(step - 1, 'back');
      }
    });
  });

  // Email form submit
  const captureForm = document.getElementById('capture-form');
  const captureEmailInput = document.getElementById('capture-email');
  const emailError = document.getElementById('email-error');
  const captureBtnText = document.getElementById('capture-btn-text');

  captureForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('capture-name').value.trim();
    const email = captureEmailInput.value.trim();

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailError.classList.remove('hidden');
      captureEmailInput.focus();
      return;
    }
    emailError.classList.add('hidden');

    // Disable button during submission
    const submitBtn = document.getElementById('capture-submit');
    submitBtn.disabled = true;
    captureBtnText.textContent = 'Loading...';

    const score = Math.round(answers.reduce((s, a) => s + a.score, 0) / 250 * 100);
    const tier = (score >= 80 ? 'Strategic Operator' : score >= 50 ? 'Aware but Drifting' : score >= 25 ? 'Operationally Trapped' : 'In Survival Mode');
    const payload = {
      name: name || null,
      email,
      score,
      tier,
      answers: answers.map(a => ({ question: a.step, answer_index: a.index, score: a.score })),
      source: document.referrer ? 'referral' : 'direct',
    };

    // Fire and forget — never block UX
    Promise.allSettled([
      submitToSupabase(payload),
      submitToWebhook(payload),
    ]).then(() => {});

    showResults();
  });

  // Skip link
  document.getElementById('capture-skip').addEventListener('click', () => {
    showResults();
  });

  // ─── API calls ───────────────────────────────────────────────────────────────

  async function submitToSupabase(payload) {
    if (!supabaseUrl || !supabaseKey) return;

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/score_submissions`, {
        method: 'POST',
        headers: {
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({
          name: payload.name,
          email: payload.email,
          score: payload.score,
          tier: payload.tier,
          answers: payload.answers,
          source: payload.source,
        }),
      });
      if (!res.ok) console.warn('Supabase insert failed:', res.status);
    } catch (err) {
      console.warn('Supabase error:', err);
    }
  }

  async function submitToWebhook(payload) {
    if (!webhookUrl) return;
    try {
      await fetch(webhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
    } catch (err) {
      console.warn('Webhook error:', err);
    }
  }
</script>
