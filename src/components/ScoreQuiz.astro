---
import { config } from '../config';

const { webhookUrl } = config.scorecard;
const { linkedin, pdfChapter1, trial: trialUrl } = config.urls;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const questions = [
  {
    text: "Hoe vaak rond je af wat je aan het begin van de week plant?",
    options: [
      { label: "Bijna altijd — 90%+ wordt gedaan", score: 25 },
      { label: "Meestal — rond de 70%", score: 19 },
      { label: "Ongeveer de helft", score: 12 },
      { label: "Zelden — minder dan 30%", score: 6 },
      { label: "Ik weet niet eens meer wat ik plande", score: 0 },
    ],
  },
  {
    text: "Heb je een systeem dat je herinnert aan je belangrijkste prioriteiten?",
    options: [
      { label: "Ja — actief, dagelijks, niet te negeren", score: 25 },
      { label: "Ja — maar ik gebruik het niet consistent", score: 19 },
      { label: "Soort van — herinneringen en lijstjes", score: 12 },
      { label: "Niet echt — alleen mijn eigen geheugen", score: 6 },
      { label: "Nee — ik vertrouw op wilskracht", score: 0 },
    ],
  },
  {
    text: "Hoeveel boeken/cursussen heb je het afgelopen jaar gevolgd waar je NU actief iets mee doet?",
    options: [
      { label: "Vrijwel alles — ik pas het direct toe", score: 25 },
      { label: "Het meeste — een paar staan op de plank", score: 19 },
      { label: "Ongeveer de helft", score: 12 },
      { label: "Een enkele — de rest verdween in mijn second brain", score: 6 },
      { label: "Niets — ik consumeer maar ik doe er niets mee", score: 0 },
    ],
  },
  {
    text: "Hoe snel vergeet je wat je leert als je het niet herhaalt?",
    options: [
      { label: "Nauwelijks — ik heb een herhalingssysteem", score: 25 },
      { label: "Langzaam — maandenlang blijft het hangen", score: 19 },
      { label: "Binnen een paar weken vervaagt het", score: 12 },
      { label: "Binnen 2 weken kwijt", score: 6 },
      { label: "Direct — ik onthoud bijna niks", score: 0 },
    ],
  },
  {
    text: "Post je consistent content die past bij je professionele doelen?",
    options: [
      { label: "Wekelijks, op ritme, met een duidelijke stem", score: 25 },
      { label: "Regelmatig — een paar keer per maand", score: 19 },
      { label: "Onregelmatig — als ik er aan denk", score: 12 },
      { label: "Zelden — ik weet niet wat ik moet zeggen", score: 6 },
      { label: "Nooit — al maanden niks gepost", score: 0 },
    ],
  },
  {
    text: "Kun je in 30 seconden benoemen wat je top-3 prioriteiten deze maand zijn?",
    options: [
      { label: "Ja — uit mijn hoofd, met deadlines", score: 25 },
      { label: "Ja — ik moet even nadenken", score: 19 },
      { label: "Twee wel, de derde niet zo scherp", score: 12 },
      { label: "Eén misschien", score: 6 },
      { label: "Nee — ik weet het echt niet", score: 0 },
    ],
  },
  {
    text: "Hoe vaak reflecteer je op wat werkte vs. wat niet?",
    options: [
      { label: "Wekelijks, gestructureerd, met aantekeningen", score: 25 },
      { label: "Regelmatig, maar informeel", score: 19 },
      { label: "Af en toe, als er iets misgaat", score: 12 },
      { label: "Zelden — ik kijk altijd vooruit", score: 6 },
      { label: "Bijna nooit", score: 0 },
    ],
  },
  {
    text: "Als iemand je execution-percentage zou meten, wat zou het zijn?",
    options: [
      { label: "Boven 85% — ik doe wat ik zeg", score: 25 },
      { label: "Rond 70% — meestal consistent", score: 19 },
      { label: "Rond 50% — hit or miss", score: 12 },
      { label: "Onder 40% — meer miss dan hit", score: 6 },
      { label: "Onder 20% — ik wil het niet weten", score: 0 },
    ],
  },
  {
    text: "Gebruik je je notities/second brain actief of is het vooral archief?",
    options: [
      { label: "Actief — ik trek er dagelijks waarde uit", score: 25 },
      { label: "Wekelijks zoek ik er dingen op", score: 19 },
      { label: "Soms — als ik iets specifieks zoek", score: 12 },
      { label: "Zelden — het is een graveyard", score: 6 },
      { label: "Nooit — pure write-only mode", score: 0 },
    ],
  },
  {
    text: "Hoeveel van je 'goede voornemens' van januari doe je nu nog?",
    options: [
      { label: "Bijna allemaal — onderdeel van mijn routine", score: 25 },
      { label: "Het meeste — een paar zijn afgevallen", score: 19 },
      { label: "Ongeveer de helft", score: 12 },
      { label: "Een enkele", score: 6 },
      { label: "Geen één — ik weet ze niet eens meer", score: 0 },
    ],
  },
];

const questionLabels = [
  "Wekelijkse afronding",
  "Prioriteit-systeem",
  "Toepassing leren",
  "Kennis-retentie",
  "Content-consistentie",
  "Top-3 helderheid",
  "Reflectie-ritme",
  "Execution-rate",
  "Second brain gebruik",
  "Voornemens vasthouden",
];
---

<div id="quiz-container" class="min-h-screen bg-void">

  <!-- Nav bar -->
  <nav class="border-b border-void-border bg-void/80 backdrop-blur-xl sticky top-0 z-10">
    <div class="max-w-content mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-sans font-semibold text-sm text-off-white hover:text-amber transition-colors">
        <div class="w-6 h-6 rounded-md bg-amber/10 border border-amber/25 flex items-center justify-center">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 2v12M2 8h12M4.5 4.5l7 7M11.5 4.5l-7 7" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        Engine Platform
      </a>
      <span id="nav-label" class="font-sans text-sm text-text-muted">Executie-Kloof Score</span>
    </div>
  </nav>

  <!-- Progress bar -->
  <div id="progress-wrapper" class="bg-void-light border-b border-void-border">
    <div class="max-w-content mx-auto px-6 py-3 flex items-center gap-4">
      <span id="progress-label" class="font-sans text-xs text-text-muted flex-shrink-0">Vraag 1 van 10</span>
      <div class="flex-1 h-1.5 bg-void-border rounded-full overflow-hidden">
        <div id="progress-fill" class="h-full bg-amber rounded-full transition-all duration-300 ease-out" style="width: 10%"></div>
      </div>
      <span id="progress-pct" class="font-mono text-xs text-text-muted flex-shrink-0 w-8 text-right">10%</span>
    </div>
  </div>

  <!-- Quiz steps -->
  <div class="max-w-narrow mx-auto px-6 py-12">

    {questions.map((q, i) => (
      <div
        id={`step-${i + 1}`}
        class={`quiz-step ${i === 0 ? '' : 'hidden'}`}
        data-step={i + 1}
      >
        <p class="font-sans text-sm font-semibold text-amber uppercase tracking-widest mb-4">
          Vraag {i + 1} van 10
        </p>
        <h2 class="font-sans font-bold text-heading-mobile text-off-white mb-8 leading-snug">
          {q.text}
        </h2>

        <div class="options space-y-3 mb-10">
          {q.options.map((opt, j) => (
            <button
              class="option-btn w-full text-left px-5 py-4 rounded-lg border border-void-border bg-void-card font-sans text-base text-off-white hover:border-amber/40 hover:bg-amber/5 transition-all duration-150"
              data-step={i + 1}
              data-index={j}
              data-score={opt.score}
            >
              {opt.label}
            </button>
          ))}
        </div>

        <div class="flex items-center justify-between">
          <button
            class="back-btn font-sans text-sm text-text-muted hover:text-off-white transition-colors flex items-center gap-1.5 disabled:opacity-30"
            data-step={i + 1}
            disabled={i === 0}
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Terug
          </button>
          <button
            class="next-btn inline-flex items-center gap-2 bg-amber text-void rounded-lg py-3 px-6 font-sans font-semibold text-base transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed hover:brightness-110 hover:-translate-y-px"
            data-step={i + 1}
            disabled
          >
            {i === 9 ? 'Zie mijn score' : 'Volgende'}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    ))}

    <!-- Email capture step -->
    <div id="capture-step" class="quiz-step hidden">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-amber/10 border border-amber/25 mb-6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke="#F5A623" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="font-sans font-bold text-heading-mobile text-off-white mb-3">Je score is klaar.</h2>
        <p class="font-sans text-base text-text-muted max-w-sm mx-auto">
          Vul je e-mail in om je volledige resultaten te zien — plus Hoofdstuk 1 van het boek als gratis download.
        </p>
      </div>

      <form id="capture-form" class="space-y-4 mb-6" novalidate>
        <div>
          <label for="capture-name" class="block font-sans text-sm font-medium text-off-white mb-1.5">
            Naam <span class="text-text-dim font-normal">(optioneel)</span>
          </label>
          <input
            type="text"
            id="capture-name"
            placeholder="Je naam"
            class="w-full border border-void-border rounded-lg px-4 py-3 font-sans text-base text-off-white bg-void-card placeholder:text-text-dim focus:outline-none focus:border-amber/60 focus:ring-1 focus:ring-amber/60 transition-colors"
          />
        </div>
        <div>
          <label for="capture-email" class="block font-sans text-sm font-medium text-off-white mb-1.5">
            E-mail <span class="text-amber font-medium">*</span>
          </label>
          <input
            type="email"
            id="capture-email"
            placeholder="jij@bedrijf.nl"
            class="w-full border border-void-border rounded-lg px-4 py-3 font-sans text-base text-off-white bg-void-card placeholder:text-text-dim focus:outline-none focus:border-amber/60 focus:ring-1 focus:ring-amber/60 transition-colors"
          />
          <p id="email-error" class="hidden mt-1.5 text-sm text-danger font-sans">Vul een geldig e-mailadres in.</p>
        </div>

        <button
          type="submit"
          id="capture-submit"
          class="w-full bg-amber text-void rounded-lg py-3.5 px-6 font-sans font-semibold text-base hover:brightness-110 transition-all duration-200 hover:-translate-y-px flex items-center justify-center gap-2"
        >
          <span id="capture-btn-text">Toon mijn resultaten</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </form>

      <div class="text-center">
        <button
          id="capture-skip"
          class="font-sans text-sm text-text-dim hover:text-text-muted transition-colors underline underline-offset-2"
        >
          Sla over — toon alleen mijn score
        </button>
      </div>
    </div>

    <!-- Results step -->
    <div id="results-step" class="quiz-step hidden">
      <!-- Populated by JS -->
    </div>

  </div>
</div>

<style>
  .quiz-step {
    transition: opacity 300ms ease-out, transform 300ms ease-out;
  }
  .quiz-step.hidden {
    display: none;
  }
  .quiz-step.exiting {
    opacity: 0;
    transform: translateX(-1rem);
  }
  .quiz-step.entering {
    opacity: 0;
    transform: translateX(1rem);
  }
  .option-btn.selected {
    background-color: rgba(42, 245, 152, 0.1);
    border-color: #2AF598;
    color: #E8E8ED;
  }
</style>

<script define:vars={{ webhookUrl, linkedin, pdfChapter1, trialUrl, supabaseUrl, supabaseKey }}>
  // ─── Data ───────────────────────────────────────────────────────────────────

  const TIERS = [
    {
      name: 'Strategic Operator',
      min: 80,
      color: '#2AF598',
      bgColor: 'rgba(42, 245, 152, 0.1)',
      borderColor: 'rgba(42, 245, 152, 0.25)',
      message: "Je systeem werkt al. Wij kunnen het versnellen — maar het is geen acuut probleem. Volg de build, sluit aan wanneer je wilt opschalen.",
      ctaLabel: 'Volg de build op LinkedIn →',
      ctaHref: linkedin,
    },
    {
      name: 'Aware but Drifting',
      min: 50,
      color: '#F5A623',
      bgColor: 'rgba(245, 166, 35, 0.1)',
      borderColor: 'rgba(245, 166, 35, 0.25)',
      message: "Je weet het. Je doet het niet consistent. Dat is precies wat we fixen. Je bent één systeem verwijderd van wekelijkse ritme.",
      ctaLabel: 'Start je 14-dagen Growth trial →',
      ctaHref: `${trialUrl}?tier=growth`,
    },
    {
      name: 'Operationally Trapped',
      min: 25,
      color: '#F5A623',
      bgColor: 'rgba(245, 166, 35, 0.12)',
      borderColor: 'rgba(245, 166, 35, 0.30)',
      message: "Dit is je wake-up call. Je weet wat je wilt — het systeem is wat ontbreekt. Geen motivatieprobleem. Een systeemprobleem.",
      ctaLabel: 'Start je 14-dagen Growth trial →',
      ctaHref: `${trialUrl}?tier=growth`,
    },
    {
      name: 'In Survival Mode',
      min: 0,
      color: '#9CA3AF',
      bgColor: 'rgba(156, 163, 175, 0.1)',
      borderColor: 'rgba(156, 163, 175, 0.25)',
      message: "Je hebt geen productiviteitstool nodig. Je hebt een systeem nodig. Begin klein — lees Hoofdstuk 1 voordat je een trial start.",
      ctaLabel: 'Download Hoofdstuk 1 (gratis PDF) →',
      ctaHref: pdfChapter1,
    },
  ];

  const QUESTION_LABELS = [
    'Wekelijkse afronding', 'Prioriteit-systeem', 'Toepassing leren', 'Kennis-retentie',
    'Content-consistentie', 'Top-3 helderheid', 'Reflectie-ritme',
    'Execution-rate', 'Second brain gebruik', 'Voornemens vasthouden',
  ];

  // ─── State ──────────────────────────────────────────────────────────────────

  let currentStep = 1;
  let answers = []; // { step, index, score, label }
  let isAnimating = false;

  // ─── DOM refs ───────────────────────────────────────────────────────────────

  const progressWrapper = document.getElementById('progress-wrapper');
  const progressFill = document.getElementById('progress-fill');
  const progressLabel = document.getElementById('progress-label');
  const progressPct = document.getElementById('progress-pct');
  const captureStep = document.getElementById('capture-step');
  const resultsStep = document.getElementById('results-step');

  function getStep(n) {
    return document.getElementById(`step-${n}`);
  }

  // ─── Navigation ─────────────────────────────────────────────────────────────

  function updateProgress(step) {
    const pct = Math.round((step / 10) * 100);
    progressFill.style.width = `${pct}%`;
    progressLabel.textContent = `Vraag ${step} van 10`;
    progressPct.textContent = `${pct}%`;
  }

  function animateTransition(outEl, inEl, direction = 'forward') {
    if (isAnimating) return;
    isAnimating = true;

    const outClass = direction === 'forward' ? 'exiting' : 'entering-back';
    const inInitClass = direction === 'forward' ? 'entering' : 'exiting-back';

    // Prepare incoming element
    inEl.classList.remove('hidden');
    inEl.style.opacity = '0';
    inEl.style.transform = direction === 'forward' ? 'translateX(1rem)' : 'translateX(-1rem)';

    // Animate out
    outEl.style.opacity = '0';
    outEl.style.transform = direction === 'forward' ? 'translateX(-1rem)' : 'translateX(1rem)';

    setTimeout(() => {
      outEl.classList.add('hidden');
      outEl.style.opacity = '';
      outEl.style.transform = '';

      inEl.style.opacity = '';
      inEl.style.transform = '';

      isAnimating = false;
    }, 300);
  }

  function goToStep(n, direction = 'forward') {
    const from = currentStep <= 10 ? getStep(currentStep) : captureStep;
    const to = getStep(n);
    if (!to) return;

    animateTransition(from, to, direction);
    currentStep = n;
    updateProgress(n);
    progressWrapper.style.display = '';

    // Restore previously selected option
    const prev = answers.find(a => a.step === n);
    if (prev) {
      const btns = to.querySelectorAll('.option-btn');
      btns.forEach((btn, i) => {
        btn.classList.toggle('selected', i === prev.index);
      });
      to.querySelector('.next-btn').disabled = false;
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function showCapture() {
    const from = getStep(10);
    animateTransition(from, captureStep);
    progressWrapper.style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function showResults() {
    const score = Math.round(answers.reduce((s, a) => s + a.score, 0) / 250 * 100);
    const tier = TIERS.find(t => score >= t.min) || TIERS[TIERS.length - 1];

    // Build breakdown — sort by score ascending, show all 10
    const breakdown = [...answers].sort((a, b) => a.score - b.score);

    resultsStep.innerHTML = buildResultsHTML(score, tier, breakdown);

    const from = captureStep.classList.contains('hidden') ? getStep(10) : captureStep;
    animateTransition(from, resultsStep);
    progressWrapper.style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function buildResultsHTML(score, tier, breakdown) {
    const shareText = encodeURIComponent(`Ik deed de Executie-Kloof Score en scoorde ${score}/100 — "${tier.name}". Benieuwd waar jij staat? engine-platform.com/score`);
    const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent('https://engine-platform.com/score')}&summary=${shareText}`;

    return `
      <div class="text-center mb-10">
        <div class="inline-block px-3 py-1.5 rounded-full text-xs font-semibold font-sans uppercase tracking-widest mb-4 border"
          style="background:${tier.bgColor}; color:${tier.color}; border-color:${tier.borderColor}">
          Jouw Executie-Kloof Score
        </div>
        <div class="font-mono text-7xl md:text-8xl font-bold mb-3 leading-none" style="color:${tier.color}">
          ${score}
        </div>
        <div class="font-mono text-sm text-text-dim mb-6">van 100</div>
        <h2 class="font-sans font-bold text-3xl text-off-white mb-5">${tier.name}</h2>
        <p class="font-sans text-lg text-text-muted max-w-narrow mx-auto leading-relaxed">
          ${tier.message}
        </p>
      </div>

      <!-- Primary CTA -->
      <div class="text-center mb-8">
        <a
          href="${tier.ctaHref}"
          class="inline-flex items-center gap-2 rounded-lg py-4 px-8 font-sans font-semibold text-base text-void transition-all duration-200 hover:-translate-y-px hover:brightness-110"
          style="background:${tier.color}"
        >
          ${tier.ctaLabel}
        </a>
      </div>

      <!-- PDF lead magnet card -->
      <div class="mb-10 border border-amber/25 rounded-xl bg-amber/5 p-6 flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-amber/15 border border-amber/30 flex items-center justify-center">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h4"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-sans text-xs font-semibold text-amber uppercase tracking-widest mb-1">Gratis bonus</p>
          <h4 class="font-sans font-semibold text-base text-off-white mb-1">Hoofdstuk 1 — Waarom je second brain je niet helpt</h4>
          <p class="font-sans text-sm text-text-muted leading-relaxed mb-3">
            Het hoofdstuk dat het hele systeem uitlegt. 18 pagina's. Geen e-mail vereist als je de score al deed.
          </p>
          <a href="${pdfChapter1}" class="inline-flex items-center gap-1.5 font-sans text-sm font-semibold text-amber hover:brightness-110 transition-colors">
            Download de PDF
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v8m0 0l-3-3m3 3l3-3M2 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <!-- Score breakdown -->
      <div class="border border-void-border rounded-xl overflow-hidden mb-8">
        <div class="px-6 py-4 bg-void-card border-b border-void-border">
          <h3 class="font-sans font-semibold text-sm text-off-white uppercase tracking-wide">Score per onderdeel</h3>
        </div>
        ${breakdown.map(a => {
          const pct = Math.round(a.score / 25 * 100);
          const barColor = a.score >= 19 ? '#2AF598' : a.score >= 12 ? '#F5A623' : '#EF4444';
          return `
          <div class="px-6 py-4 border-b border-void-border last:border-b-0 flex items-center gap-4">
            <div class="flex-1 min-w-0">
              <div class="font-sans text-sm font-medium text-off-white">${QUESTION_LABELS[a.step - 1]}</div>
              <div class="mt-1.5 h-1.5 bg-void-border rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-500" style="width:${pct}%; background:${barColor}"></div>
              </div>
            </div>
            <div class="font-mono text-sm flex-shrink-0 w-10 text-right" style="color:${barColor}">${a.score}/25</div>
          </div>`;
        }).join('')}
      </div>

      <!-- Secondary actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a
          href="${linkedinShareUrl}"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-sans text-sm font-medium text-amber hover:brightness-110 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
          Deel je score op LinkedIn
        </a>
        <span class="hidden sm:block text-void-border">|</span>
        <a href="/" class="font-sans text-sm text-text-muted hover:text-off-white transition-colors">
          ← Hoe Engine Platform werkt
        </a>
      </div>
    `;
  }

  // ─── Event listeners ─────────────────────────────────────────────────────────

  // Option selection
  document.querySelectorAll('.option-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.step);
      const index = parseInt(btn.dataset.index);
      const score = parseInt(btn.dataset.score);
      const label = btn.textContent.trim();

      // Update answers state
      answers = answers.filter(a => a.step !== step);
      answers.push({ step, index, score, label });

      // Update UI selection
      const parent = btn.closest('.options');
      parent.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');

      // Enable next button
      const stepEl = document.getElementById(`step-${step}`);
      stepEl.querySelector('.next-btn').disabled = false;
    });
  });

  // Next buttons
  document.querySelectorAll('.next-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.step);
      if (step < 10) {
        goToStep(step + 1, 'forward');
      } else {
        showCapture();
      }
    });
  });

  // Back buttons
  document.querySelectorAll('.back-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.step);
      if (step > 1) {
        goToStep(step - 1, 'back');
      }
    });
  });

  // Email form submit
  const captureForm = document.getElementById('capture-form');
  const captureEmailInput = document.getElementById('capture-email');
  const emailError = document.getElementById('email-error');
  const captureBtnText = document.getElementById('capture-btn-text');

  captureForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('capture-name').value.trim();
    const email = captureEmailInput.value.trim();

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailError.classList.remove('hidden');
      captureEmailInput.focus();
      return;
    }
    emailError.classList.add('hidden');

    // Disable button during submission
    const submitBtn = document.getElementById('capture-submit');
    submitBtn.disabled = true;
    captureBtnText.textContent = 'Bezig…';

    const score = Math.round(answers.reduce((s, a) => s + a.score, 0) / 250 * 100);
    const tier = (score >= 80 ? 'Strategic Operator' : score >= 50 ? 'Aware but Drifting' : score >= 25 ? 'Operationally Trapped' : 'In Survival Mode');
    const payload = {
      name: name || null,
      email,
      score,
      tier,
      answers: answers.map(a => ({ question: a.step, answer_index: a.index, score: a.score })),
      source: document.referrer ? 'referral' : 'direct',
    };

    // Fire and forget — never block UX
    Promise.allSettled([
      submitToSupabase(payload),
      submitToWebhook(payload),
    ]).then(() => {});

    showResults();
  });

  // Skip link
  document.getElementById('capture-skip').addEventListener('click', () => {
    showResults();
  });

  // ─── API calls ───────────────────────────────────────────────────────────────

  async function submitToSupabase(payload) {
    if (!supabaseUrl || !supabaseKey) return;

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/score_submissions`, {
        method: 'POST',
        headers: {
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({
          name: payload.name,
          email: payload.email,
          score: payload.score,
          tier: payload.tier,
          answers: payload.answers,
          source: payload.source,
        }),
      });
      if (!res.ok) console.warn('Supabase insert failed:', res.status);
    } catch (err) {
      console.warn('Supabase error:', err);
    }
  }

  async function submitToWebhook(payload) {
    if (!webhookUrl) return;
    try {
      await fetch(webhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
    } catch (err) {
      console.warn('Webhook error:', err);
    }
  }
</script>
