---
import SectionLabel from './ui/SectionLabel.astro';
import FAQItem from './ui/FAQItem.astro';

const faqs = [
  {
    question: 'How much of my time does this actually require?',
    answer: '5 minutes per day. You respond to two messages — your morning priorities and your evening check-in. That\'s it.',
  },
  {
    question: 'Is this just a chatbot?',
    answer: 'No. It\'s a configured AI accountability system running on your own dedicated server. It knows your goals, tracks your patterns, and generates weekly analysis. It also won\'t let you BS your way through a check-in.',
  },
  {
    question: 'What if I already use Todoist / Notion / a planner?',
    answer: 'Those are input tools — they capture what you want to do. This is output infrastructure — it measures what you actually did. They work together.',
  },
  {
    question: 'What happens after 12 weeks?',
    answer: 'The system keeps running. Your server, your data. Start a new 12-week cycle, add modules, or continue with managed hosting (€50/month) for maintenance.',
  },
  {
    question: 'I\'m not technical. Do I need to manage a server?',
    answer: 'No. You interact with a Telegram or Slack bot. I handle everything technical. You\'ll never see a terminal, a dashboard, or a config file.',
  },
  {
    question: 'What\'s the founding member benefit?',
    answer: 'You lock in €997 permanently (regular price: €2,497). Direct access to me for feedback. Founding member bonuses including the Execution Playbook, private community channel, and monthly office hours. And you help shape the system with your input.',
  },
  {
    question: 'What if it doesn\'t work for me?',
    answer: 'Triple guarantee. 14-day quick win guarantee, 30-day execution guarantee, and uptime commitment. If your execution doesn\'t improve, full refund.',
  },
];

const notForYou = [
  'You\'re looking for another to-do list or productivity app.',
  'You won\'t commit 5 minutes a day to the check-in process.',
  'You prefer comfortable excuses over uncomfortable truth.',
  'You want someone to do the work for you. The system tracks execution — you still have to execute.',
];
---

<section id="faq" class="bg-void py-section-mobile md:py-section animate-on-scroll">
  <div class="max-w-narrow mx-auto px-6">

    <!-- Who this is NOT for -->
    <div class="mb-16">
      <SectionLabel text="Fair Warning" />
      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-6">
        This is not for everyone.
      </h2>
      <p class="font-sans text-text-muted mb-6 leading-relaxed">
        Execution Engine is not for you if:
      </p>
      <ul class="space-y-3">
        {notForYou.map((item) => (
          <li class="flex items-start gap-3 font-sans text-text-muted">
            <span class="text-amber mt-0.5 flex-shrink-0">✕</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="font-sans text-text-muted mt-6 leading-relaxed">
        But if you're a professional who knows what they need to do and just needs a system
        that makes it <strong class="text-off-white">unavoidable</strong> — keep reading.
      </p>
    </div>

    <!-- FAQ -->
    <SectionLabel text="FAQ" />
    <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-10">
      Common questions.
    </h2>

    <div class="border-t border-void-border">
      {faqs.map((faq) => (
        <FAQItem question={faq.question} answer={faq.answer} />
      ))}
    </div>

  </div>
</section>
