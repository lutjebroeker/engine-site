---
import SectionLabel from './ui/SectionLabel.astro';
import FAQItem from './ui/FAQItem.astro';

const faqs = [
  {
    question: 'Moet ik van tool wisselen?',
    answer: 'Nee. Schrijf waar je wilt — Obsidian, Notion, Apple Notes, voice memo, Telegram. Wij pluggen erin. Jij blijft in je eigen workflow.',
  },
  {
    question: 'Is dit weer een second brain app?',
    answer: 'Nee. We bouwen geen input-tool. We bouwen output: content, kennis, discipline. De waarde zit niet in waar je schrijft, maar in wat er daarna mee gebeurt.',
  },
  {
    question: 'Wat als ik alleen execution wil?',
    answer: 'Prima. Start met één module (Starter, €47/mo). Voeg Create of Learn toe wanneer je klaar bent. Je upgrade met één klik, zonder nieuwe onboarding.',
  },
  {
    question: 'Is mijn data veilig?',
    answer: 'Alles draait op je eigen infrastructuur of onze Europese servers. Geen big tech. Geen training op jouw data. Jij bent de eigenaar.',
  },
  {
    question: 'Hoe snel merk ik resultaat?',
    answer: 'Week 1: je eerste execution score. Week 2: eerste content vanuit je eigen geheugen. Maand 3: het systeem kent je patronen en confronteert je ermee.',
  },
  {
    question: 'Hoeveel tijd kost het?',
    answer: '5 minuten per dag. Twee berichten beantwoorden — ochtendprioritieten en avondcheck-in. Verder doet het systeem het werk.',
  },
  {
    question: 'Wat na de 14 dagen trial?',
    answer: 'Automatisch betaald abonnement vanaf dag 15. Opzeggen met één klik, in één menu. Geen trucs, geen cancellation calls.',
  },
];
---

<section id="faq" class="bg-void py-section-mobile md:py-section animate-on-scroll">
  <div class="max-w-narrow mx-auto px-6">

    <SectionLabel text="FAQ" />
    <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-10">
      Vragen die mensen vaak stellen.
    </h2>

    <div class="border-t border-void-border">
      {faqs.map((faq) => (
        <FAQItem question={faq.question} answer={faq.answer} />
      ))}
    </div>

  </div>
</section>
