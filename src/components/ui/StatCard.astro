---
interface Props {
  number: string;
  description: string;
  accent?: 'emerald' | 'amber';
}

const { number, description, accent = 'emerald' } = Astro.props;

const numberColor = accent === 'amber' ? 'text-amber' : 'text-emerald';
---

<div class="glass-card rounded-xl p-6 text-left">
  <div class={`font-mono text-4xl font-medium mb-2 ${numberColor}`}>{number}</div>
  <div class="text-sm text-text-muted font-sans leading-snug">{description}</div>
</div>
