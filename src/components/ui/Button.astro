---
interface Props {
  variant?: 'primary' | 'secondary' | 'amber';
  href?: string;
  'data-cta'?: string;
  class?: string;
  size?: 'default' | 'large';
}

const {
  variant = 'primary',
  href = '#',
  'data-cta': dataCta,
  class: className = '',
  size = 'default',
} = Astro.props;

const base = 'inline-flex items-center gap-2 rounded-lg font-sans font-semibold transition-all duration-200 cursor-pointer';
const sizing = size === 'large' ? 'py-4 px-8 text-lg' : 'py-3.5 px-7 text-base';

const variants = {
  primary:   'bg-emerald text-void hover:brightness-110 hover:-translate-y-px shadow-lg shadow-emerald/20',
  secondary: 'bg-transparent border border-void-border-light text-off-white hover:bg-void-card hover:border-emerald/30 hover:-translate-y-px',
  amber:     'bg-amber text-void hover:brightness-110 hover:-translate-y-px shadow-lg shadow-amber/20',
};
---

<a
  href={href}
  data-cta={dataCta}
  class={`${base} ${sizing} ${variants[variant]} ${className}`}
>
  <slot />
</a>
