---
import SectionLabel from './ui/SectionLabel.astro';
import ChatDemo from './react/ChatDemo';
---

<section class="bg-void py-section-mobile md:py-section animate-on-scroll">
  <div class="max-w-content mx-auto px-6">

    <div class="text-center mb-12">
      <SectionLabel text="See It In Action" />

      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-4">
        5 minutes. Twice a day. That's it.
      </h2>

      <p class="font-sans text-lg text-text-muted max-w-narrow mx-auto leading-relaxed">
        Every morning, your AI sets priorities. Every evening, it holds you accountable.
        Watch a real interaction below.
      </p>
    </div>

    <div class="max-w-[640px] mx-auto">
      <ChatDemo client:visible />
    </div>

    <p class="text-center text-sm text-text-dim font-sans mt-8">
      Delivered via Telegram or Slack. Runs on your own server. Your data never leaves your infrastructure.
    </p>

  </div>
</section>
