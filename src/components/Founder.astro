---
import { config } from '../config';
import SectionLabel from './ui/SectionLabel.astro';

const { linkedin } = config.urls;
---

<section class="bg-void-light py-section-mobile md:py-section animate-on-scroll">
  <div class="max-w-content mx-auto px-6">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

      <!-- Photo / Visual -->
      <div class="flex justify-center">
        <div class="relative">
          <!-- Placeholder for photo -->
          <div class="w-64 h-64 md:w-80 md:h-80 rounded-2xl bg-void-card border border-void-border flex items-center justify-center overflow-hidden">
            <div class="text-center p-8">
              <div class="w-20 h-20 rounded-full bg-emerald/10 border border-emerald/20 mx-auto mb-4 flex items-center justify-center">
                <span class="text-3xl font-bold text-emerald font-sans">J</span>
              </div>
              <p class="text-sm text-text-dim font-sans">Jelle Spek</p>
            </div>
          </div>
          <!-- Decorative glow -->
          <div class="absolute -inset-4 bg-emerald/5 rounded-3xl blur-2xl -z-10"></div>
        </div>
      </div>

      <!-- Bio -->
      <div>
        <SectionLabel text="The Builder" />

        <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-6">
          Built by someone with the same problem.
        </h2>

        <div class="space-y-4 font-sans text-text-muted leading-relaxed">
          <p>
            I'm Jelle. I built the Execution Engine because I was tired of being the person
            who knew exactly what to do and still didn't do it.
          </p>
          <p>
            My background is in <strong class="text-off-white">local-first AI infrastructure</strong> — self-hosted
            systems that run on your own hardware, with your own data, under your own control. I've spent
            years building AI systems that are private by default.
          </p>
          <p>
            The Execution Engine started as my personal accountability system. I built the AI check-ins
            for myself, tracked my own execution score, and watched my output change. Then I realized
            the system was the product.
          </p>
          <p>
            I share the build process publicly on LinkedIn — what's working, what isn't, and what I'm
            learning. No polished marketing. Just process.
          </p>
        </div>

        <div class="flex items-center gap-6 mt-8">
          <a
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-void-card border border-void-border text-off-white text-sm font-medium hover:border-emerald/30 transition-all"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-text-muted">
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
            </svg>
            Follow the build on LinkedIn
          </a>
        </div>

      </div>
    </div>

  </div>
</section>
