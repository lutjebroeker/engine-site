---
import { config } from '../config';
import SectionLabel from './ui/SectionLabel.astro';
import Arrow from './icons/Arrow.astro';

const { linkedin } = config.urls;
---

<section class="bg-cream py-section animate-on-scroll">
  <div class="max-w-narrow mx-auto px-6">

    <SectionLabel text="Transparency" />

    <h3 class="font-serif text-subheading text-charcoal mb-6">
      We show our work.
    </h3>

    <div class="space-y-5 font-sans text-lg text-warm-gray leading-relaxed mb-8">
      <p>
        The Execution Engine is a system I built for myself — because I had the same problem you do.
        I'm now opening it to 12 founding members who want the same results.
      </p>
      <p>
        I share weekly updates on what I'm building, what's working, and what I'm learning.
        No polished marketing. Just process.
      </p>
    </div>

    <a
      href={linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 font-sans font-semibold text-forest hover:text-forest-dark transition-colors"
    >
      Follow the build on LinkedIn
      <Arrow />
    </a>

  </div>
</section>
