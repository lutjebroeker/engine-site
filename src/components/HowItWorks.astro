---
import SectionLabel from './ui/SectionLabel.astro';

const steps = [
  {
    number: '01',
    title: 'We configure your system',
    body: 'In a 60-minute onboarding call, we map your goals, schedule, and patterns. Within 48 hours, your personal accountability system is live on a dedicated server — configured for you, owned by you.',
    icon: '⚙️',
  },
  {
    number: '02',
    title: 'Your AI checks in daily',
    body: 'Every morning: your top 3 priorities, aligned to your 12-week goals. Every evening: a simple check — did you do what you said? No feelings. Just facts. Via Telegram or Slack.',
    icon: '💬',
  },
  {
    number: '03',
    title: 'You see the truth, weekly',
    body: "Every Sunday: an AI-generated execution report. What you executed. What you didn't. Patterns detected. Your execution score. The number doesn't lie.",
    icon: '📊',
  },
];
---

<section id="how-it-works" class="bg-void py-section-mobile md:py-section relative animate-on-scroll">
  <div class="absolute inset-0 grid-pattern opacity-20"></div>

  <div class="relative max-w-content mx-auto px-6">

    <div class="text-center mb-12">
      <SectionLabel text="How It Works" />
      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white">
        Three steps. We build it. You use it.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children animate-on-scroll">
      {steps.map((step) => (
        <div class="card-3d group bg-void-card border border-void-border rounded-xl p-8 hover:border-emerald/20 transition-all duration-300 relative overflow-hidden">
          <!-- Hover glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-emerald/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

          <div class="relative">
            <div class="flex items-center justify-between mb-6">
              <span class="font-mono text-5xl font-bold text-void-border-light group-hover:text-emerald/30 transition-colors">{step.number}</span>
              <span class="text-2xl">{step.icon}</span>
            </div>
            <h4 class="font-sans font-semibold text-xl text-off-white mb-3 group-hover:text-emerald transition-colors">
              {step.title}
            </h4>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{step.body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
