---
import SectionLabel from './ui/SectionLabel.astro';

const steps = [
  {
    number: '01',
    title: '"Waar schrijf je nu?"',
    body: 'We pluggen een connector op je bestaande tool. Obsidian, Notion, Apple Notes, voice memo — maakt niet uit. Je hoeft niks te wisselen.',
  },
  {
    number: '02',
    title: 'Je geheugen vult zich',
    body: 'Alles wat je schrijft wordt semantisch geïndexeerd door Open Brain. Op je eigen infrastructuur of onze Europese servers.',
  },
  {
    number: '03',
    title: 'Modules gaan werken',
    body: 'Content, learning, execution — automatisch, vanuit jouw context. Niks generieks. Alles uit jouw eigen geheugen.',
  },
  {
    number: '04',
    title: 'Het vliegwiel draait',
    body: 'Elke week wordt het systeem slimmer. Na 90 dagen kent het je patronen — wanneer je afhaakt, waar je goed in bent, wat je nog niet door hebt.',
  },
];
---

<section id="how-it-works" class="bg-void py-section-mobile md:py-section relative animate-on-scroll">
  <div class="absolute inset-0 grid-pattern opacity-20"></div>

  <div class="relative max-w-content mx-auto px-6">

    <div class="text-center max-w-narrow mx-auto mb-14">
      <SectionLabel text="Hoe het werkt" />
      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-4">
        Eén vraag. Eén connector. Eén systeem.
      </h2>
      <p class="font-sans text-lg text-text-muted leading-relaxed">
        Geen nieuwe tool leren. Geen migratie. Geen workflows die breken.
      </p>
    </div>

    <!-- Timeline / stepper -->
    <div class="max-w-[720px] mx-auto relative">
      <!-- Vertical connecting line (desktop) -->
      <div class="hidden md:block absolute left-[28px] top-8 bottom-8 w-px bg-gradient-to-b from-amber/40 via-void-border to-amber/10"></div>

      <div class="space-y-5 stagger-children animate-on-scroll">
        {steps.map((step) => (
          <div class="relative flex gap-5 items-start bg-void-card border border-void-border rounded-xl p-6 hover:border-amber/25 transition-all duration-300">
            <div class="flex-shrink-0 w-14 h-14 rounded-lg bg-amber/10 border border-amber/25 flex items-center justify-center relative z-10">
              <span class="font-mono text-xl font-bold text-amber">{step.number}</span>
            </div>
            <div class="pt-1.5">
              <h4 class="font-sans font-semibold text-xl text-off-white mb-2">{step.title}</h4>
              <p class="font-sans text-base text-text-muted leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
