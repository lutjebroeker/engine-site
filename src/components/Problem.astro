---
import SectionLabel from './ui/SectionLabel.astro';

const pains = [
  {
    title: 'De executie-kloof',
    body: 'Je plant perfect. Week 3: alles vergeten. De helft van wat je maandag afsprak, staat vrijdag nog open.',
    icon: 'M12 4v16M4 12h16',
  },
  {
    title: 'De kennis-illusie',
    body: 'Je leest. Je studeert. Maar je vergeet 80% binnen 2 weken. Je second brain zit vol notities die je nooit meer opent.',
    icon: 'M12 4a8 8 0 100 16 8 8 0 000-16zm0 4v4l3 2',
  },
  {
    title: 'De content-stilte',
    body: 'Je weet genoeg om te posten. Je hebt ideeën te over. Maar je doet het niet consistent. Terwijl je stem juist nu nodig is.',
    icon: 'M4 4h16v12H5l-1 4V4z',
  },
];
---

<section id="problem" class="bg-void py-section-mobile md:py-section animate-on-scroll">
  <div class="max-w-content mx-auto px-6">

    <div class="max-w-narrow">
      <SectionLabel text="Het probleem" />
      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-8">
        Je weet wat je moet doen.<br class="hidden md:block" />
        <span class="text-danger/90">Je doet het niet.</span>
      </h2>

      <div class="space-y-4 font-sans text-lg text-text-muted leading-relaxed mb-16">
        <p>
          Je hebt boeken gelezen. Cursussen gevolgd. Planners gekocht. Apps geïnstalleerd.
        </p>
        <p>
          Je second brain zit vol met notities die je nooit meer opent. Je weet méér dan ooit. Je doet minder dan je zou willen.
        </p>
        <p class="text-off-white">
          Dat is geen motivatieprobleem. Dat is een systeemprobleem.
        </p>
      </div>
    </div>

    <!-- 3 pain cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 stagger-children animate-on-scroll">
      {pains.map((p) => (
        <div class="relative bg-void-card border border-void-border rounded-xl p-7 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-danger/5 to-transparent pointer-events-none"></div>
          <div class="relative">
            <div class="w-10 h-10 rounded-lg bg-danger/10 border border-danger/20 flex items-center justify-center mb-5">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={p.icon} />
              </svg>
            </div>
            <h3 class="font-sans font-semibold text-lg text-off-white mb-2">{p.title}</h3>
            <p class="font-sans text-sm text-text-muted leading-relaxed">{p.body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
