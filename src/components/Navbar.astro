---
import { config } from '../config';

const { scorecard } = config.urls;

const navLinks = [
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Results', href: '#proof' },
  { label: 'Pricing', href: '#offer' },
  { label: 'FAQ', href: '#faq' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-wide mx-auto px-6 flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-lg bg-emerald/10 border border-emerald/20 flex items-center justify-center group-hover:bg-emerald/20 transition-colors">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8l4 4 6-7" stroke="#2AF598" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="font-sans font-semibold text-off-white text-sm tracking-tight">
        Execution Engine
      </span>
    </a>

    <!-- Links (desktop) -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a href={link.href} class="font-sans text-sm text-text-muted hover:text-off-white transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <a
      href={scorecard}
      class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-emerald/10 border border-emerald/20 text-emerald text-sm font-medium hover:bg-emerald/20 transition-all"
    >
      Take the Assessment
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-text-muted hover:text-off-white p-2" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-void-border bg-void/95 backdrop-blur-xl">
    <div class="px-6 py-4 space-y-3">
      {navLinks.map((link) => (
        <a href={link.href} class="block font-sans text-sm text-text-muted hover:text-off-white transition-colors py-2">
          {link.label}
        </a>
      ))}
      <a
        href={scorecard}
        class="block text-center px-4 py-2.5 rounded-lg bg-emerald/10 border border-emerald/20 text-emerald text-sm font-medium mt-4"
      >
        Take the Assessment
      </a>
    </div>
  </div>
</nav>

<script>
  // Scroll behavior: add backdrop + border on scroll
  const navbar = document.getElementById('navbar');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (scrollY > 50) {
      navbar?.classList.add('bg-void/80', 'backdrop-blur-xl', 'border-b', 'border-void-border');
    } else {
      navbar?.classList.remove('bg-void/80', 'backdrop-blur-xl', 'border-b', 'border-void-border');
    }
    lastScroll = scrollY;
  });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
