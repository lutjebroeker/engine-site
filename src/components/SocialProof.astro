---
import SectionLabel from './ui/SectionLabel.astro';
import CircularProgress from './react/CircularProgress';
import AnimatedCounter from './react/AnimatedCounter';
---

<section id="proof" class="bg-void-light py-section-mobile md:py-section animate-on-scroll">
  <div class="max-w-content mx-auto px-6">

    <div class="text-center mb-12">
      <SectionLabel text="Results" />
      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-4">
        I built this for myself first.
      </h2>
      <p class="font-sans text-lg text-text-muted max-w-narrow mx-auto">
        Before opening to founding members, I ran the system on myself for 8 weeks.
        Here's what the data shows.
      </p>
    </div>

    <!-- Score Trajectory -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">

      <!-- Progress circles -->
      <div class="bg-void-card border border-void-border rounded-xl p-8 flex flex-col items-center justify-center">
        <p class="text-xs font-sans uppercase tracking-widest text-text-dim mb-6">Before → After</p>
        <div class="flex items-center gap-8">
          <CircularProgress value={34} label="Week 1" color="#6B7280" client:visible />
          <div class="text-text-dim">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
          <CircularProgress value={82} label="Week 8" client:visible />
        </div>
      </div>

      <!-- Key stats -->
      <div class="bg-void-card border border-void-border rounded-xl p-8 space-y-6">
        <p class="text-xs font-sans uppercase tracking-widest text-text-dim">Key Metrics</p>
        <div>
          <div class="flex items-baseline gap-2">
            <AnimatedCounter target={141} suffix="%" className="text-emerald text-3xl font-bold" client:visible />
          </div>
          <p class="text-sm text-text-muted mt-1">improvement in execution score</p>
        </div>
        <div>
          <div class="flex items-baseline gap-2">
            <AnimatedCounter target={56} className="text-emerald text-3xl font-bold" client:visible />
            <span class="text-text-muted text-lg">days</span>
          </div>
          <p class="text-sm text-text-muted mt-1">consecutive daily check-ins</p>
        </div>
        <div>
          <div class="flex items-baseline gap-2">
            <AnimatedCounter target={12} className="text-emerald text-3xl font-bold" client:visible />
          </div>
          <p class="text-sm text-text-muted mt-1">execution patterns identified by AI</p>
        </div>
      </div>

      <!-- Weekly report excerpt -->
      <div class="bg-void-card border border-void-border rounded-xl p-8">
        <p class="text-xs font-sans uppercase tracking-widest text-text-dim mb-4">Weekly Report Excerpt</p>
        <blockquote class="border-l-2 border-emerald pl-4 text-text-muted font-sans text-sm leading-relaxed italic">
          "Week 6 execution score: 78%. Up from 71% last week. Pattern detected: Tuesday and Wednesday
          consistently low — back-to-back meetings block deep work. Recommendation: protect Tuesday
          morning as a non-negotiable focus block."
        </blockquote>
        <p class="mt-4 text-xs text-text-dim font-sans">
          AI-generated. Based on real check-in data.
        </p>
      </div>

    </div>

    <!-- Testimonial placeholder ready for future use -->
    <div class="text-center p-8 rounded-xl border border-dashed border-void-border">
      <p class="text-sm text-text-dim font-sans">
        Founding cohort results will appear here as pilots complete.
      </p>
    </div>

  </div>
</section>
