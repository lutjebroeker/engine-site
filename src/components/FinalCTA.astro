---
import { config } from '../config';
import Button from './ui/Button.astro';
import Arrow from './icons/Arrow.astro';

const { scorecard } = config.urls;
---

<section class="relative bg-void py-section-mobile md:py-section overflow-hidden animate-on-scroll">
  <!-- Background effects -->
  <div class="absolute inset-0 aurora-bg opacity-60"></div>
  <div class="absolute inset-0 grid-pattern opacity-25"></div>

  <!-- Lamp effect -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[conic-gradient(from_90deg_at_50%_0%,transparent_30%,rgba(245,166,35,0.10)_50%,transparent_70%)] blur-[50px] pointer-events-none"></div>

  <div class="relative max-w-content mx-auto px-6 text-center">

    <h2 class="font-sans font-bold text-display-mobile md:text-display text-off-white mb-5">
      Stop met plannen.<br />
      <span class="text-amber">Begin met doen.</span>
    </h2>

    <p class="font-sans text-text-muted text-lg mb-10 max-w-narrow mx-auto leading-relaxed">
      Je weet al wat je moet doen. Wat je mist is een systeem dat het onvermijdelijk maakt.
    </p>

    <!-- Dual CTA -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-4">
      <Button href={scorecard} data-cta="scorecard-final" variant="primary" size="large">
        Doe de Executie-Kloof Score
        <Arrow />
      </Button>
      <Button href="#pricing" variant="secondary" size="large">
        Bekijk de pricing
      </Button>
    </div>

    <p class="text-sm text-text-dim font-sans">
      Niet klaar om te beslissen? Doe de gratis score — die vertelt je wat je nodig hebt.
    </p>

  </div>
</section>
