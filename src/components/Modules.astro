---
import SectionLabel from './ui/SectionLabel.astro';

const modules = [
  {
    id: 'execute',
    name: 'Execute',
    tagline: 'Weet wat je wilt. Houdt je eerlijk.',
    icon: 'M5 13l4 4L19 7',
    features: [
      '12-week goal tracking',
      'Dagelijkse AI check-ins (ochtend + avond)',
      'Execution score — een getal, geen gevoel',
      "Patroonherkenning ('je mist consequent woensdagen')",
      'Anti-gaming detectie',
    ],
  },
  {
    id: 'create',
    name: 'Create',
    tagline: 'Kent je stem. Maakt je content.',
    icon: 'M12 19l7-7 3 3-7 7-3-3zM18 13l-6-6-2 2 6 6zM2 2l7.586 7.586M11 11l-4 4',
    features: [
      'Vangt content-ideeën op uit je geheugen',
      'Schrijft in jouw stem op basis van je brand voice',
      "Volgt Priestley's publicatie-ritme",
      'Van idee naar draft naar publicatie',
    ],
  },
  {
    id: 'learn',
    name: 'Learn',
    tagline: 'Weet wat je kunt. Houdt je scherp.',
    icon: 'M12 14l9-5-9-5-9 5 9 5zM12 14l6.16-3.422A12.083 12.083 0 0119 16.79 11.95 11.95 0 0112 20.055a11.95 11.95 0 01-7-3.265A12.083 12.083 0 015.84 10.578L12 14z',
    features: [
      'Spaced repetition op je eigen kennisbestand',
      'Proactieve herinneringen als kennis wegroest',
      '6 leertechnieken (Feynman, Retrieval Practice, …)',
      'Koppelt geleerde kennis terug naar execution en content',
    ],
  },
];
---

<section id="modules" class="relative bg-void py-section-mobile md:py-section animate-on-scroll overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-30"></div>

  <div class="relative max-w-content mx-auto px-6">

    <div class="text-center max-w-narrow mx-auto mb-14">
      <SectionLabel text="De oplossing" />
      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-5">
        Niet nóg een tool.<br />
        <span class="text-amber">Een geheugen dat handelt.</span>
      </h2>
      <p class="font-sans text-lg text-text-muted leading-relaxed">
        Drie modules. Één geheugen. Elke module trekt eruit wat relevant is — en voedt het weer terug.
      </p>
    </div>

    <!-- Three module cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 stagger-children animate-on-scroll mb-14">
      {modules.map((m) => (
        <div class="group relative bg-void-card border border-void-border rounded-xl p-7 hover:border-amber/30 transition-all duration-300 overflow-hidden flex flex-col">
          <!-- Hover glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-amber/8 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

          <div class="relative flex flex-col flex-1">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-amber/10 border border-amber/25 flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={m.icon} />
                </svg>
              </div>
              <h3 class="font-sans font-bold text-2xl text-off-white">{m.name}</h3>
            </div>

            <p class="font-sans text-base text-amber mb-5 leading-snug">
              {m.tagline}
            </p>

            <ul class="space-y-2.5 font-sans text-sm text-text-muted leading-relaxed flex-1">
              {m.features.map((f) => (
                <li class="flex items-start gap-2.5">
                  <svg class="flex-shrink-0 mt-0.5 text-amber" width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M3 7.5L5.5 10l5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Vliegwiel blurb -->
    <div class="relative max-w-narrow mx-auto text-center border border-void-border rounded-xl bg-void-card/60 px-8 py-8">
      <div class="inline-flex items-center gap-2 mb-3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12a9 9 0 11-3-6.7M21 4v5h-5" />
        </svg>
        <span class="font-sans text-xs font-semibold text-amber uppercase tracking-widest">Het vliegwiel</span>
      </div>
      <p class="font-sans text-base text-text-muted leading-relaxed">
        Elke module trekt uit het geheugen wat relevant is en voedt het weer terug.
        <span class="text-off-white">Na 90 dagen kent het systeem je patronen.</span>
      </p>
    </div>

  </div>
</section>
