---
const guarantees = [
  {
    title: 'The 14-Day Quick Win Guarantee',
    description: 'If you don\'t execute more in 14 days than the previous 14 — full refund. No questions, no forms, no friction.',
    icon: '⚡',
    accent: 'emerald',
  },
  {
    title: 'The 30-Day Execution Guarantee',
    description: 'Use the system for 30 days. If your execution score doesn\'t measurably improve — measured by your own data — full refund.',
    icon: '🎯',
    accent: 'emerald',
  },
  {
    title: 'The Uptime Commitment',
    description: 'If the AI ever misses a scheduled check-in, your next month of hosting is free. The system shows up even when you don\'t.',
    icon: '🛡️',
    accent: 'amber',
  },
];
---

<section class="bg-void py-section-mobile md:py-section animate-on-scroll">
  <div class="max-w-content mx-auto px-6">

    <div class="text-center mb-12">
      <h2 class="font-sans font-bold text-heading-mobile md:text-heading text-off-white mb-4">
        Triple-stacked guarantee.
      </h2>
      <p class="font-sans text-lg text-text-muted max-w-narrow mx-auto">
        Saying "yes" should feel safer than saying "no."
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {guarantees.map((g) => (
        <div class="bg-void-card border border-void-border rounded-xl p-8 text-center hover:border-emerald/20 transition-all duration-300">
          <div class="text-3xl mb-4">{g.icon}</div>
          <h3 class="font-sans font-semibold text-off-white text-lg mb-3">{g.title}</h3>
          <p class="font-sans text-sm text-text-muted leading-relaxed">{g.description}</p>
        </div>
      ))}
    </div>

    <p class="text-center mt-8 text-sm text-text-dim font-sans">
      The only requirement: respond to your daily check-ins. The system can't help you if you don't show up.
    </p>

  </div>
</section>
